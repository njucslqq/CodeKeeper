# Git Deep Analyzer 配置文件示例
# 复制此文件为 .git-deep-analyzer.yaml 并根据需要修改

git:
  # Git仓库路径
  repo_path: /path/to/your/repo

  # 分支名称
  branch: main

  # 时间范围配置
  time_range:
    # 开始日期 (YYYY-MM-DD)
    since: "2024-01-01"
    # 结束日期 (YYYY-MM-DD)，留空表示到现在
    until: null

  # 时间基准: author_time, commit_time, merge_time
  time_basis: author_time

analysis:
  # AI提供商: openai, anthropic
  ai_provider: openai

  # AI模型
  ai_model: gpt-4

  # 分析维度
  dimensions:
    - technical
    - business
    - evolution

  # 执行策略: serial, parallel, layered, incremental
  execution_strategy: parallel

  # 重试配置
  retry:
    max_retries: 3
    base_delay: 1.0
    max_delay: 60.0
    failure_behavior: retry  # retry, continue, abort, fallback

# 外部系统集成配置
external:
  # Jira配置
  jira:
    # Jira服务器URL
    url: https://your-domain.atlassian.net

    # 认证方式:
    # 方式1: Personal Access Token
    token: ${JIRA_TOKEN}

    # 方式2: Basic Auth
    # username: ${JIRA_USERNAME}
    # password: ${JIRA_PASSWORD}

    # JQL查询
    jql: "project = YOUR_PROJECT"

  # Confluence配置
  confluence:
    # Confluence服务器URL
    url: https://your-domain.atlassian.net/wiki

    # 认证
    token: ${CONFLUENCE_TOKEN}

    # 空间key
    space_key: YOUR_SPACE

# 报告配置
reporting:
  # 输出格式: html, markdown
  format: html

  # 详细程度: concise, standard, detailed
  detail_level: standard

  # 输出目录
  output_dir: ./reports

  # 文件名格式: {repo}-{branch}-{timestamp}.{ext}
  filename_format: "{repo}-{branch}-{timestamp}.{ext}"

  # 交互功能
  interactive:
    enable_search: true
    enable_filter: true
    enable_collapse: true
    enable_detail_switch: true

# 日志配置
logging:
  # 日志级别: debug, info, warning, error
  level: info

  # 日志输出
  log_to_console: true
  log_to_file: true
  log_file: ./git-deep-analyzer.log

  # 记录AI请求和响应
  log_ai_requests: true
  log_ai_responses: true

  # 记录性能指标
  log_performance: true
CONFIG
